# Aratea dashboard — environment variables
#
# Copy to .env.local (gitignored) for local dev. On Vercel, set these in the
# project's Environment Variables UI. Keys prefixed with NEXT_PUBLIC_ are
# exposed in the browser bundle — do not put secrets there.

# RPC endpoint for Arbitrum Sepolia (testnet only in Phase 1).
NEXT_PUBLIC_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Chain ID. Arbitrum Sepolia = 421614. Override for local dev (Anvil = 31337).
NEXT_PUBLIC_CHAIN_ID=421614

# Deployed contract addresses. Empty until M4 deployment is executed against the
# testnet — the dashboard renders a "not yet deployed" notice when these are zero.
NEXT_PUBLIC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Block number from which the dashboard starts scanning RoundProposed / Executed
# / Cancelled / Challenged events. Set this to the block number of the contract
# deployment transaction; saves time and free-tier RPC quota.
NEXT_PUBLIC_DEPLOY_BLOCK=0

# Optional: override the public block explorer URL (default: arbiscan.io for
# Arbitrum Sepolia testnet).
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.arbiscan.io
