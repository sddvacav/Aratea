# predictor/.env.example
#
# Copy to predictor/.env (gitignored) for local use. Never commit a
# real webhook URL — those grant write access to the Discord channel
# they target.
#
# Channel-name → env-var mapping for predictor/scripts/post_to_discord.py:
#   --channel predictions   → DISCORD_WEBHOOK_PREDICTIONS
#   --channel pnl-tracker   → DISCORD_WEBHOOK_PNL_TRACKER
#   --channel build-log     → DISCORD_WEBHOOK_BUILD_LOG
#
# Get a webhook URL from Discord:
#   Server settings → Integrations → Webhooks → New Webhook → Copy URL.

DISCORD_WEBHOOK_PREDICTIONS=
DISCORD_WEBHOOK_PNL_TRACKER=
DISCORD_WEBHOOK_BUILD_LOG=
